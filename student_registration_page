<!DOCTYPE html>
<html lang="en">

<head>
    <title>student registration form</title>
    <link href="./assests/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background-color: chartreuse;">
    <h2 style="margin: 10px;"><u>Student Registration Form</u></h2>
    <div style="margin-left:35px; margin-right: 65%;">
        <div>First name:</div>
        <input type="text" class="from-control" placeholder="first name" style="width:50%;">
        <div>Last name:</div>
        <input type="text" placeholder="last name" style="width:50%;">
        <div>Email:</div>
        <input type="text" placeholder="email" style="width:50%">
        <div>Phoneno:</div>
        <input type="text" placeholder="phoneno" style="width:50%">
        <div>Date of birth</div>
        <input type="Date" placeholder="Date">
        <div>Address:</div>
        <input type="text" placeholder="address">
        <div>Password</div>
        <input type="text" placeholder="password" style="width: 25%;">
        <input type="text" placeholder="confirm-password" style="width:25%">
        <br>
        <label><h6>Gender :</h6></label>
            <label> Male</label>
            <input type="radio" placeholder="male">
            <label>Female</label>
            <input type="radio" placeholder="female">
            <br>
        <input type="button" class="btn btn-primary ms-5" value="Submit">
    </div>
</body>

</html>
